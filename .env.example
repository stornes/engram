# Required: Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for `bun run apply-migrations.ts`: direct postgres connection
# (Supabase Dashboard → Project Settings → Database → Connection string → URI).
# Not used by server.ts or the sync scripts.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Required: OpenAI (for classification + fallback embeddings)
OPENAI_API_KEY=sk-your-openai-key

# Optional: Voyage AI (primary embeddings, recommended)
VOYAGE_API_KEY=pa-your-voyage-key

# Optional: Email sync (Apple Mail via AppleScript, macOS only)
SELF_EMAIL=you@example.com
MAIL_ACCOUNT=Exchange
# MAIL_LOOKBACK_DAYS=7

# Optional: Calendar sync (EventKit via Swift, macOS only)
# EVENTS_SWIFT_PATH=./tools/get_events.swift

# Optional: Slack sync
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNELS=C0YOUR1CHANNEL

# Optional: Linear
LINEAR_API_KEY=lin_api_your-linear-key

# Optional: Supabase Management API
SUPABASE_ACCESS_TOKEN=sbp_your-access-token

# Optional: Override the destination domain for sync scripts.
# One of: ob_work, ob_personal, ob_life, ob_learning.
# Defaults per script: email/slack/calendar/notion-meetings -> ob_work,
# sessions/pai-context -> ob_learning.
# ENGRAM_DOMAIN=ob_personal
