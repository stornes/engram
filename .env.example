# Required: Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required: OpenAI (for classification + fallback embeddings)
OPENAI_API_KEY=sk-your-openai-key

# Optional: Voyage AI (primary embeddings, recommended)
VOYAGE_API_KEY=pa-your-voyage-key

# Optional: Slack sync
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNELS=C0YOUR1CHANNEL

# Optional: Linear
LINEAR_API_KEY=lin_api_your-linear-key

# Optional: Supabase Management API
SUPABASE_ACCESS_TOKEN=sbp_your-access-token
